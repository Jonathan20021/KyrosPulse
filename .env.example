## Aplicacion
APP_NAME="Kyros Pulse"
APP_URL=http://localhost/KyrosPulse/public
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:CHANGE_THIS_GENERATE_RANDOM_KEY
APP_TIMEZONE=America/Santo_Domingo
APP_LOCALE=es

## Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kyros_pulse
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

## Sesiones
SESSION_LIFETIME=120
SESSION_NAME=kyros_pulse_session
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

## Wasapi (WhatsApp)
WASAPI_BASE_URL=https://api.wasapi.io/api/v1
WASAPI_API_KEY=
WASAPI_WEBHOOK_SECRET=

## Resend (Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Kyros Pulse <no-reply@kyrosrd.com>"
RESEND_REPLY_TO=

## Claude (IA)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-6
CLAUDE_API_URL=https://api.anthropic.com/v1/messages
CLAUDE_VERSION=2023-06-01
CLAUDE_MAX_TOKENS=2048

## Almacenamiento
STORAGE_PATH=storage
UPLOAD_MAX_SIZE=20971520
UPLOAD_ALLOWED_MIME="image/jpeg,image/png,image/gif,image/webp,application/pdf,audio/mpeg,audio/ogg,video/mp4"

## Rate limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_API=120
RATE_LIMIT_API_WINDOW=60

## Logs
LOG_LEVEL=debug
LOG_CHANNEL=daily
